{
  "realm": "owldrive",
  "enabled": true,
  "accessTokenLifespan": 300,
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "resetPasswordAllowed": true,
  "verifyEmail": false,
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "OWL Drive administrator"
      },
      {
        "name": "user",
        "description": "OWL Drive regular user"
      }
    ]
  },
  "clients": [
    {
      "clientId": "owl-drive-web",
      "name": "OWL Drive Web",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:3000",
        "http://localhost:3000/*",
        "http://127.0.0.1:3000",
        "http://127.0.0.1:3000/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://127.0.0.1:3000"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:3000/*##http://127.0.0.1:3000/*"
      }
    }
  ],
  "users": [
    {
      "username": "testuser",
      "enabled": true,
      "email": "testuser@example.com",
      "emailVerified": true,
      "firstName": "Test",
      "lastName": "User",
      "realmRoles": [
        "user"
      ],
      "credentials": [
        {
          "type": "password",
          "value": "TestPassword123!",
          "temporary": false
        }
      ]
    },
    {
      "username": "adminuser",
      "enabled": true,
      "email": "adminuser@example.com",
      "emailVerified": true,
      "firstName": "Admin",
      "lastName": "User",
      "realmRoles": [
        "admin"
      ],
      "credentials": [
        {
          "type": "password",
          "value": "AdminPassword123!",
          "temporary": false
        }
      ]
    }
  ]
}
